<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/theme_preset_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6.0dp"
    app:cardCornerRadius="14.0dp"
    app:cardElevation="0.0dp"
    app:strokeWidth="1.0dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12.0dp">

        <LinearLayout
            android:id="@+id/theme_preset_preview"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="40.0dp"
            android:layout_marginBottom="8.0dp" />

        <TextView
            android:id="@+id/theme_preset_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
