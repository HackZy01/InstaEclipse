<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="10.0dp"
    android:paddingBottom="10.0dp"
    android:background="?selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <View
        android:id="@+id/theme_slot_swatch"
        android:layout_width="36.0dp"
        android:layout_height="36.0dp"
        android:layout_marginEnd="14.0dp" />

    <TextView
        android:id="@+id/theme_slot_label"
        android:layout_width="0.0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

    <TextView
        android:id="@+id/theme_slot_hex"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?colorOnSurfaceVariant" />

</LinearLayout>
