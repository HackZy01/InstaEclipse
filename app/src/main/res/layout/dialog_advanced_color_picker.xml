<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="24.0dp"
    android:paddingEnd="24.0dp"
    android:paddingTop="8.0dp"
    android:paddingBottom="8.0dp">

    <ps.reso.instaeclipse.ui.theme.AdvancedColorPickerView
        android:id="@+id/color_picker_view"
        android:layout_width="match_parent"
        android:layout_height="220.0dp" />

    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12.0dp">

        <View
            android:id="@+id/color_preview_swatch"
            android:layout_width="28.0dp"
            android:layout_height="28.0dp"
            android:layout_marginEnd="12.0dp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/color_hex_input"
            android:layout_width="0.0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.0"
            android:inputType="textCapCharacters"
            android:singleLine="true"
            android:fontFamily="monospace" />
    </LinearLayout>

    <TextView
        android:id="@+id/color_rgb_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12.0dp"
        android:fontFamily="monospace"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8.0dp"
        android:text="R"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium" />
    <SeekBar
        android:id="@+id/color_red_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="G"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium" />
    <SeekBar
        android:id="@+id/color_green_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="B"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium" />
    <SeekBar
        android:id="@+id/color_blue_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/color_alpha_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4.0dp"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium" />
    <SeekBar
        android:id="@+id/color_alpha_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8.0dp" />

</LinearLayout>
