<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout android:fitsSystemWindows="true" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.appbar.AppBarLayout android:fitsSystemWindows="true" android:layout_width="match_parent" android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar android:id="@+id/theme_toolbar" android:layout_width="match_parent" android:layout_height="?actionBarSize"
            app:navigationIcon="@drawable/ic_chevron_right" app:title="@string/theme_title" app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingBottom="32.0dp">

            <!-- Master enable switch -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_margin="16.0dp" app:cardCornerRadius="16.0dp" app:cardElevation="0.0dp" app:strokeWidth="1.0dp" app:strokeColor="?colorOutlineVariant">
                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="16.0dp">
                    <TextView android:layout_width="0.0dp" android:layout_height="wrap_content" android:layout_weight="1.0"
                        android:text="@string/theme_enable" android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/theme_enable_switch"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Presets section -->
            <LinearLayout android:id="@+id/theme_presets_header" android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="20.0dp" android:paddingEnd="20.0dp"
                android:paddingTop="8.0dp" android:paddingBottom="8.0dp" android:background="?selectableItemBackground" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0.0dp" android:layout_height="wrap_content" android:layout_weight="1.0"
                    android:text="@string/theme_section_presets" android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                <ImageView android:id="@+id/theme_presets_expand_icon" android:layout_width="24.0dp" android:layout_height="24.0dp"
                    android:src="@drawable/ic_expand_less" android:contentDescription="@string/theme_collapse_section" />
            </LinearLayout>
            <LinearLayout android:id="@+id/theme_presets_content" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/theme_preset_list" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:paddingStart="12.0dp" android:paddingEnd="12.0dp" android:clipToPadding="false" android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <!-- Custom colors section -->
            <LinearLayout android:id="@+id/theme_custom_header" android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="20.0dp" android:paddingEnd="20.0dp"
                android:paddingTop="16.0dp" android:paddingBottom="8.0dp" android:background="?selectableItemBackground" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0.0dp" android:layout_height="wrap_content" android:layout_weight="1.0"
                    android:text="@string/theme_section_custom" android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                <ImageView android:id="@+id/theme_custom_expand_icon" android:layout_width="24.0dp" android:layout_height="24.0dp"
                    android:src="@drawable/ic_expand_less" android:contentDescription="@string/theme_collapse_section" />
            </LinearLayout>
            <LinearLayout android:id="@+id/theme_custom_content" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/theme_color_slots" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:paddingStart="16.0dp" android:paddingEnd="16.0dp" android:clipToPadding="false" android:nestedScrollingEnabled="false" />
                <com.google.android.material.button.MaterialButton android:id="@+id/theme_reset_custom" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_margin="16.0dp" android:text="@string/theme_reset_custom" style="@style/Widget.Material3.Button.TonalButton" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
